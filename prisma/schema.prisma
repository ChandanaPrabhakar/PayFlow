generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id          String   @id
  amount      Int
  currency    String
  email       String?
  status      String
  createdAt   DateTime @default(now())
}