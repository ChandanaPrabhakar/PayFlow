generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id            String   @id //Stripe PaymentIntent.id  -> payment level idempotency
  userId        String?
  amount        Int
  currency      String
  email         String?
  status        String
  stripeEventId String?  @unique //Webhook level idempotency
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id])
  receipt       Receipt?

  @@index([email])
  @@index([createdAt])
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  createdAt    DateTime      @default(now())
  transactions Transaction[]
}

model WebhookEvent {
  id        String   @id
  type      String
  payload   Json
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Receipt {
  id            String   @id @default(uuid())
  transactionId String   @unique
  url           String
  email         String
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id])
}
